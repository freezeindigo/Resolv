# LLM providers
# Groq is used for Tier 2 reasoning, hypothesis agents, pattern interpreter, and judge.
# Free tier is sufficient for small eval runs (< 500 complaints).
GROQ_API_KEY=

# Anthropic is used for the arbiter (paper-mode: claude-haiku; production: claude-sonnet).
ANTHROPIC_API_KEY=

# OpenAI is required only for GPT-4o baseline comparisons.
# If not set, scripts/run_eval.py will run ARIA-only and skip the baseline.
OPENAI_API_KEY=

# PostgreSQL — required for full paper eval (NDA corpus) and API server.
# Not needed for scripts/run_eval.py --dataset (synthetic sample mode).
DATABASE_URL=postgresql://localhost/resolv

# Redis — required for pattern state (cluster detection) in production mode.
# Not needed for eval with --no-context flag.
REDIS_URL=redis://localhost:6379
